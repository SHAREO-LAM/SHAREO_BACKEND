# LOCAL DEVELOPMENT (docker-compose.yml)
# Le backend se connecte au postgres du container via le service name "postgres"
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=shareo
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# PRODUCTION / SANDBOX (docker-compose-backend.yml on VM)
# Le backend se connecte au postgres de la machine hôte
# DB_HOST=127.0.0.1      (localhost depuis le container = IP de la VM)
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=<mot_de_passe_securise>
# DB_NAME=shareo         (ou shareo_sb pour sandbox)
# NODE_ENV=production
# JWT_SECRET=<votre_jwt_secret>